<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
	version="3.1">

	<display-name>SapConsultingApp1</display-name>
	<description>SAP Consulting Management System - JEE Fallstudie</description>

	<!-- JSF FacesServlet explizit konfiguriert -->
	<servlet>
		<servlet-name>FacesServlet</servlet-name>
		<servlet-class>javax.faces.webapp.FacesServlet</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>

	<servlet-mapping>
		<servlet-name>FacesServlet</servlet-name>
		<url-pattern>*.xhtml</url-pattern>
	</servlet-mapping>

	<!-- Willkommensseite leitet auf DashboardServlet -->
	<welcome-file-list>
		<welcome-file>index.xhtml</welcome-file>
	</welcome-file-list>

	<!-- JSF Projektphase: Development fuer detaillierte Fehlermeldungen -->
	<context-param>
		<param-name>javax.faces.PROJECT_STAGE</param-name>
		<param-value>Development</param-value>
	</context-param>

	<!-- Facelets als Standard-Viewhandler -->
	<context-param>
		<param-name>javax.faces.FACELETS_SUFFIX</param-name>
		<param-value>.xhtml</param-value>
	</context-param>

	<!-- Session-Timeout in Minuten -->
	<session-config>
		<session-timeout>30</session-timeout>
	</session-config>

	<!-- Fehlerseiten (JSP) -->
	<error-page>
		<error-code>404</error-code>
		<location>/fehler.jsp</location>
	</error-page>
	<error-page>
		<error-code>500</error-code>
		<location>/fehler.jsp</location>
	</error-page>

</web-app>
